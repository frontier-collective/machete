{
  "identifier": "default",
  "description": "Default capabilities for the Machete app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "dialog:default",
    "dialog:allow-open",
    "shell:allow-open",
    "window-state:default",
    "core:window:allow-start-dragging",
    "core:window:allow-is-maximized",
    "core:window:allow-maximize",
    "core:window:allow-unmaximize",
    "updater:default",
    "process:default"
  ]
}
